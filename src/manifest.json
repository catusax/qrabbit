{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "chromium:manifest_version": 3,
  "firefox:manifest_version": 2,
  "default_locale": "en",
  "version": "1.0.0",
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "icons": {
    "16": "images/icon.png",
    "32": "images/icon.png",
    "48": "images/icon.png",
    "64": "images/icon.png",
    "128": "images/icon.png"
  },
  "chromium:action": {
    "default_icon": {
      "16": "images/icon.png",
      "32": "images/icon.png",
      "48": "images/icon.png",
      "64": "images/icon.png",
      "128": "images/icon.png"
    },
    "default_title": "__MSG_actionTitle__",
    "default_popup": "popup/index.html"
  },
  "firefox:browser_action": {
    "default_icon": {
      "16": "images/icon.png",
      "32": "images/icon.png",
      "48": "images/icon.png",
      "64": "images/icon.png",
      "128": "images/icon.png"
    },
    "default_title": "__MSG_actionTitle__",
    "default_popup": "popup/index.html"
  },
  "chromium:side_panel": {
    "default_path": "sidebar/index.html",
    "default_title": "__MSG_sidebarPanelTitle__"
  },
  "firefox:sidebar_action": {
    "default_panel": "sidebar/index.html",
    "default_title": "__MSG_sidebarPanelTitle__"
  },
  "chromium:permissions": [
    "sidePanel",
    "contextMenus",
    "tabs",
    "activeTab"
  ],
  "chromium:host_permissions": [
    "<all_urls>"
  ],
  "firefox:permissions": [
    "<all_urls>",
    "contextMenus",
    "tabs",
    "activeTab"
  ],
  "background": {
    "chromium:service_worker": "background.js",
    "firefox:scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/scripts.js"
      ]
    }
  ],
  "author": "QRabbit"
}